# InvoiceAPI — Local Development Environment
# Copy from .env.example and fill in real values

NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Database (Neon PostgreSQL) — REQUIRED
DATABASE_URL=postgresql://user:password@your-neon-host.neon.tech/invoiceapi?sslmode=require

# Upstash Redis — REQUIRED for rate limiting
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Mistral OCR API — REQUIRED for production OCR
# Get your key at: https://console.mistral.ai/
MISTRAL_API_KEY=

# OpenAI API Key — REQUIRED for extraction
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# AWS S3 (optional — for production file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-central-1
AWS_S3_BUCKET=invoiceapi-uploads

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Sentry (optional)
SENTRY_DSN=
