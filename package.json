{
  "name": "invoiceapi",
  "version": "1.0.0",
  "description": "InvoiceAPI - SaaS B2B pour extraction automatique de données factures (Swiss QR-factures)",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9.0.1",
    "@fastify/rate-limit": "^10.2.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "drizzle-orm": "^0.38.0",
    "fastify": "^5.8.4",
    "openai": "^6.33.0",
    "pdf-lib": "^1.17.1",
    "pino": "^10.0.0",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.8",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.9",
    "drizzle-kit": "^0.31.10",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^9.21.0",
    "@eslint/js": "^9.21.0",
    "supertest": "^7.1.0",
    "@types/supertest": "^6.0.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.6"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
